{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "students": {
      ".indexOn": [
        "code",
        "level"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$studentId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $studentId)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        "xp": {
          ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || (auth.uid === $studentId && newData.isNumber() && newData.val() >= data.val() && newData.val() <= data.val() + 100))"
        },
        "xpLog": {
          "$key": {
            ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || (auth.uid === $studentId && !data.exists() && newData.val() === true))"
          }
        },
        "xpHistory": {
          "$entry": {
            ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $studentId)"
          }
        },
        "examAttempts": {
          "$examId": {
            ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || (auth.uid === $studentId && !data.exists()))"
          }
        }
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $uid)",
        ".validate": "newData.hasChildren(['name', 'level', 'xp']) && newData.child('xp').isNumber()"
      }
    },
    "content": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".indexOn": [
        "level",
        "category",
        "createdAt"
      ]
    },
    "online_exams": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "community": {
      ".read": "auth != null",
      "$postId": {
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || newData.child('studentKey').val() === auth.uid)"
      }
    },
    "support": {
      ".indexOn": [
        "studentKey"
      ],
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || (query.orderByChild == 'studentKey' && query.equalTo == auth.uid))",
      "$ticketId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('studentKey').val() === auth.uid)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || (!data.exists() && newData.child('studentKey').val() === auth.uid))",
        ".validate": "newData.hasChildren(['studentKey', 'studentName', 'text', 'date']) && newData.child('studentKey').isString() && newData.child('studentName').isString() && newData.child('text').isString()"
      }
    },
    "grades": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$gradeId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('studentKey').val() === auth.uid)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || newData.child('studentKey').val() === auth.uid)"
      }
    },
    "invoices": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "expenses": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "attendance": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "homework": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "staff": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "schedule": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "registration_requests": {
      ".indexOn": [
        "code",
        "phone",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$requestId": {
        ".write": "(auth != null && root.child('admins').child(auth.uid).val() === true) || (!data.exists() && newData.child('status').val() === 'pending')",
        ".validate": "newData.hasChildren(['name', 'code', 'phone', 'level', 'status', 'createdAt']) && newData.child('name').isString() && newData.child('code').isString() && newData.child('phone').isString() && newData.child('level').isString() && newData.child('status').isString()"
      }
    },
    "assignments": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".indexOn": [
        "level",
        "dueDate"
      ]
    },
    "submissions": {
      ".indexOn": [
        "studentKey",
        "assignmentKey",
        "level"
      ],
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || (query.orderByChild == 'studentKey' && query.equalTo == auth.uid))",
      "$submissionId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('studentKey').val() === auth.uid)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || newData.child('studentKey').val() === auth.uid)",
        ".validate": "newData.hasChildren(['assignmentKey', 'studentKey', 'studentName', 'date'])"
      }
    },
    "live_classes": {
      ".indexOn": [
        "status",
        "level",
        "teacherUid"
      ],
      ".read": "auth != null",
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || data.child('participants').child(auth.uid).exists())",
        "participants": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $uid || root.child('live_classes').child($sessionId).child('teacherUid').val() === auth.uid)"
          }
        },
        "chat": {
          "$msg": {
            ".read": "auth != null",
            ".write": "auth != null && root.child('live_classes').child($sessionId).child('participants').child(auth.uid).exists()"
          }
        },
        "signals": {
          "$uid": {
            "$sig": {
              ".read": "auth != null && auth.uid === $uid",
              ".write": "auth != null && root.child('live_classes').child($sessionId).child('participants').child(auth.uid).exists()"
            }
          }
        }
      }
    },
    "live_recordings": {
      ".indexOn": [
        "sessionId",
        "createdAt"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "notifications": {
      ".indexOn": [
        "level",
        "studentKey",
        "createdAt"
      ],
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$notificationId": {
        ".validate": "newData.hasChildren(['title', 'body', 'createdAt']) && newData.child('title').isString() && newData.child('body').isString()"
      }
    },
    "question_bank": {
      ".indexOn": [
        "level",
        "category",
        "difficulty"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "student_reports": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$studentId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $studentId)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "admin_profiles": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "audit_logs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".indexOn": [
        "at",
        "by"
      ]
    },
    "active_sessions": {
      ".indexOn": [
        "lastSeen",
        "level"
      ],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".validate": "newData.hasChildren(['deviceId', 'lastSeen'])"
      },
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "student_activity": {
      ".indexOn": [
        "lastSeen",
        "level"
      ],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)"
      },
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "lesson_progress": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        "$lessonId": {
          ".validate": "newData.hasChildren(['lessonKey', 'percent', 'updatedAt']) && newData.child('percent').isNumber() && newData.child('percent').val() >= 0 && newData.child('percent').val() <= 100"
        }
      },
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "live_attendance": {
      ".indexOn": [
        "sessionId",
        "level"
      ],
      "$sessionId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          ".validate": "newData.hasChildren(['studentKey', 'joinedAt', 'lastSeen'])"
        }
      },
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "student_notifications": {
      ".indexOn": [
        "createdAt",
        "level",
        "type",
        "read"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $uid)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $uid)"
      }
    },
    "notification_reads": {
      "$uid": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $uid)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $uid)"
      }
    },
    "mega_records": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "campaigns": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "automation_rules": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "payment_plans": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "coupons": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "learning_paths": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "risk_alerts": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "library_files": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "lesson_quizzes": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "parent_messages": {
      ".indexOn": [
        "type",
        "level",
        "studentKey",
        "createdAt",
        "status"
      ],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || auth.uid === $uid)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    }
  }
}